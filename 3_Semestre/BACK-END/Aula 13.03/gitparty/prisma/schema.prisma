// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Usuarios {
  id            Int          @id @default(autoincrement())
  nome          String
  email         String       @unique
  senha         String
  data_cadastro DateTime     @default(now())
  inscricoes    inscricoes[]
}

model Eventos {
  id                Int          @id @default(autoincrement())
  titulo            String
  descricao         String
  data_evento       DateTime
  local             String
  capacidade_maxima Int
  status            StatusEvento @default(ATIVO)

  inscricoes inscricoes[]
  Img Img[]
}

model inscricoes {
  id             Int             @id @default(autoincrement())
  data_inscricao DateTime        @default(now())
  status         StatusInscricao @default(CONFIRMADO)
  eventos        Eventos         @relation(fields: [eventosID], references: [id])
  eventosID      Int
  usuarios       Usuarios       @relation(fields: [usuariosId], references: [id])
  usuariosId     Int
}

model Img {
  id Int @id @default(autoincrement())
  nomeOriginal String 
  nomeArquivo String
  mimeType String
  path String
  data DateTime @default(now())
  eventos Eventos @relation(fields: [eventosID], references: [id])
  eventosID Int
}

enum StatusInscricao {
  CONFIRMADO
  LISTA_DE_ESPERA
  CANCELADO
}

enum StatusEvento {
  ATIVO
  CANCELADO
  ENCERRADO
}
