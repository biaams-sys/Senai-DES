generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}


model Task {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}